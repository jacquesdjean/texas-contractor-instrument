SOCRATA_APP_TOKEN=your_socrata_app_token
GOOGLE_SHEETS_CREDS=base64_encoded_service_account_json
# Accepts a plain spreadsheet ID or full Google Sheets URL
GOOGLE_SHEET_ID=your_google_sheet_id

# Slack notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFICATION_EMAIL=recipient@example.com

# TSBPE plumbing scraper (optional, set to 1 to enable)
ENABLE_TSBPE=0

# Backfill: seed the sheet with N weeks of recent licenses (0 = normal run)
BACKFILL_WEEKS=0
